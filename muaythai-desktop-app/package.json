{
  "name": "muaythai-desktop-app",
  "version": "1.0.0",
  "description": "App desktop de gestão de atletas e mensalidades da Vipers Fight Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "build": {
    "appId": "com.vipersfightteam.gestao",
    "productName": "Vipers Fight Team - Gestão",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "app.js",
      "styles.css",
      "logo.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "logo.png"
    }
  }
}
